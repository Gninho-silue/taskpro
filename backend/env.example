# ============================================
# CONFIGURATION SÉCURISÉE - TASKPRO BACKEND
# ============================================
# Copiez ce fichier vers .env et remplissez vos valeurs réelles
# ATTENTION: Le fichier .env ne doit JAMAIS être commité dans Git !

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-key-at-least-256-bits-long-here-make-it-very-secure
JWT_EXPIRATION=86400000

# Database Configuration
DB_URL=jdbc:postgresql://localhost:5432/taskprodb
DB_USERNAME=taskpro
DB_PASSWORD=taskpro

# Email Configuration
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=your-email
MAIL_PASSWORD=your-password

# File Upload Configuration
FILE_UPLOAD_PATH=./uploads
MAX_FILE_SIZE=52428800

# Security Configuration
BCRYPT_STRENGTH=12

# Logging Configuration
LOG_LEVEL=DEBUG
